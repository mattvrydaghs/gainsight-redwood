{
  "widgets": [
    {
      "category": "Demo",
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Title",
            "defaultValue": "React Widget",
            "rules": {
              "required": true
            }
          },
          {
            "name": "description",
            "type": "text",
            "label": "Description",
            "defaultValue": "A widget built with React and the Widget SDK."
          }
        ]
      },
      "containers": [
        "Full width"
      ],
      "defaultConfig": {
        "title": "React Widget",
        "description": "A widget built with React and the Widget SDK."
      },
      "description": "A React widget using the ESM module pattern with Widget SDK",
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": true,
        "movable": true
      },
      "title": "React Widget",
      "version": "1.0.0",
      "widgetsLibrary": true,
      "type": "react_widget",
      "source": {
        "path": "widgets/react_widget/dist",
        "entry": "index.html"
      },
      "imageSrc": "widgets/react_widget/thumbnail.png"
    },
    {
      "category": "Custom",
      "containers": [
        "Full width"
      ],
      "description": "React widget for the Tidal Downloads Page",
      "imageName": "dynamic_content",
      "settings": {
        "configurable": false,
        "container": false,
        "editable": false,
        "movable": true,
        "removable": true,
        "shared": false
      },
      "title": "Tidal Downloads Widget",
      "version": "1.0.0",
      "widgetsLibrary": true,
      "type": "tidal_downloads",
      "source": {
        "path": "widgets/tidal_downloads/dist",
        "entry": "index.html"
      }
    }
  ],
  "stylesheets": [
    {
      "rules": [
        {
          "field": "pageType",
          "operator": "in",
          "value": [
            "global"
          ]
        }
      ],
      "name": "theme",
      "description": "Shared design tokens and component styles",
      "path": "./stylesheets/theme/style.css"
    }
  ],
  "scripts": [
    {
      "rules": [
        {
          "field": "pageType",
          "operator": "in",
          "value": [
            "global"
          ]
        }
      ],
      "placement": "head",
      "name": "global",
      "description": "Global Javascript",
      "path": "./scripts/global/script.js"
    }
  ]
}
